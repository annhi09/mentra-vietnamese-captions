# Server port - The port on which the application will run (default: 3000)
PORT=3000

# App package name - Your application's unique identifier.  Make sure it exactly matches the package name in the MentraOS Developer Console
PACKAGE_NAME=com.thienlong14th.vietnamese-safe-captions

# API key - Your MentraOS developer API key from the MentraOS Developer Console (never commit the key to source control)
MENTRAOS_API_KEY=your_api_key_here

# Caption display mode: ascii strips Vietnamese diacritics, original preserves them on glasses
VIETNAMESE_DISPLAY_MODE=ascii

# Number of recent final caption lines shown on glasses
GLASSES_MAX_LINES=4

# How long the recent final captions should remain visible on glasses
GLASSES_DISPLAY_DURATION_MS=4000
